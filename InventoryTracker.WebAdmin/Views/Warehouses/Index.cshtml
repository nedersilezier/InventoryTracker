@using InventoryTracker.WebAdmin.ViewModels.Dashboard
@model InventoryTracker.WebAdmin.ViewModels.Warehouses.WarehousesIndexViewModel

@{
    ViewData["Title"] = "Warehouses";
    ViewData["ActiveNav"] = "Warehouses";
}
<div class="flex gap-8">
    @* sidebar with filters and stats *@
    <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-24">
            <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-4">
                <div class="mb-6 px-2">
                    <p class="text-[11px] text-slate-500 font-medium uppercase tracking-wider">
                        Search and filter
                    </p>
                </div>

                <form asp-controller="Warehouses" asp-action="Index" method="get" class="space-y-4">
                    <input type="hidden" asp-for="PageSize" />
                    <input type="hidden" name="PageNumber" value="1" />
                    <div>
                        <label asp-for="SearchTerm"
                               class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">
                            Search
                        </label>

                        <input asp-for="SearchTerm"
                               class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200"
                               placeholder="Name, code, city, country..." />
                    </div>

                    <button type="submit"
                            class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white text-xs font-bold py-3 rounded-full shadow-lg">
                        Apply Filters
                    </button>
                </form>
            </div>
            <div class="grid grid-cols-1 grid-rows-3 gap-4 mb-8 mt-8">
                <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-100">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-1">
                        Applied filters
                    </span>
                    <div class="text-sm font-semibold text-slate-900 mt-2">
                        @(string.IsNullOrWhiteSpace(Model.SearchTerm) ? "None" : Model.SearchTerm)
                    </div>
                </div>
            </div>
        </div>
    </aside>
    <section class="flex-1 min-w-0">
        @* header *@
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 mb-2">
                    Warehouses
                </h1>
                <p class="text-sm text-slate-500 max-w-2xl">
                    Browse and manage warehouses.
                </p>
            </div>

            <div class="flex items-center gap-3">
                <a asp-controller="Warehouses"
                       asp-action="Create"
                       class="px-5 py-2.5 rounded-full bg-blue-600 text-white text-sm font-semibold shadow hover:bg-blue-700 transition">
                    + New Warehouse
                </a>
            </div>
        </div>
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm">
                @successMessage
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm">
                @errorMessage
            </div>
        }
        @* table *@
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <colgroup>
                        <col class="w-[14%]" />
                        <col class="w-[10%]" />
                        <col class="w-[36%]" />
                        <col class="w-[15%]" />
                        <col class="w-[5%]" />
                        <col class="w-[20%]" />
                    </colgroup>
                    <thead>
                        <tr class="bg-slate-50 border-y border-slate-100">
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                                Warehouse
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                                Code
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                                Address
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                                Country
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                                Stock Entries
                            </th>
                            <th class="px-6 py-4 text-right text-[10px] font-bold uppercase tracking-widest text-slate-500">
                                Actions
                            </th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-50">
                        @if (Model.Warehouses.Any())
                        {
                            @foreach (var warehouse in Model.Warehouses)
                            {
                                <tr class="hover:bg-slate-100 transition-colors group">
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-900">
                                                    @warehouse.Name
                                                </div>
                                                <div class="text-[11px] text-slate-400">
                                                    @warehouse.City
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-6 py-5 text-sm font-mono text-slate-500">
                                        @warehouse.Code
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-sm text-slate-700">
                                            @(warehouse.AddressLine1 ?? "-")
                                        </div>
                                        <div class="text-sm text-slate-400">
                                            @(warehouse.AddressLine2 ?? "-")
                                        </div>
                                    </td>

                                    <td class="px-6 py-5 text-sm text-slate-700">
                                        @warehouse.CountryName
                                    </td>

                                    <td class="px-6 py-5">
                                        <span class="px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider">
                                            @warehouse.StockEntriesCount
                                        </span>
                                    </td>

                                    <td class="px-6 py-5 text-right">
                                        <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <a asp-controller="Warehouses"
                                                   asp-action="Details"
                                                   asp-route-id="@warehouse.WarehouseId"
                                                   class="p-2 hover:bg-slate-100 rounded-lg">
                                                <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">Description</span>
                                            </a>

                                            <a asp-controller="Warehouses"
                                                   asp-action="Edit"
                                                   asp-route-id="@warehouse.WarehouseId"
                                                   class="p-2 hover:bg-slate-100 rounded-lg">
                                                <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">edit</span>
                                            </a>
                                            @if (warehouse.IsActive)
                                            {
                                                <form asp-controller="Warehouses"
                                                      asp-action="Deactivate"
                                                      method="post"
                                                      class="inline">
    
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@warehouse.WarehouseId" />
                                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Warehouses")" />

                                                    <button type="submit"
                                                            class="p-2 hover:bg-slate-100 rounded-lg group"
                                                            onclick="return confirm('Are you sure you want to deactivate this warehouse?')">
                                                        <span class="material-symbols-outlined text-slate-400 hover:text-red-400">
                                                            Delete
                                                        </span>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-controller="Warehouses"
                                                      asp-action="Activate"
                                                      method="post"
                                                      class="inline">
    
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@warehouse.WarehouseId" />
                                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Warehouses")" />

                                                    <button type="submit"
                                                            class="p-2 hover:bg-slate-100 rounded-lg group"
                                                            onclick="return confirm('Are you sure you want to activate this warehouse?')">
                                                        <span class="material-symbols-outlined text-slate-400 hover:text-green-400">
                                                            restore_from_trash
                                                        </span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-10 text-center text-sm text-slate-400">
                                    No warehouses found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("Partials/_TableFooter", Model.TableFooter)
        </div>
    </section>
</div>