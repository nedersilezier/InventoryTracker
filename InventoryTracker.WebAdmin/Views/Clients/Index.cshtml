@using InventoryTracker.WebAdmin.ViewModels.Dashboard
@model InventoryTracker.WebAdmin.ViewModels.Clients.ClientsIndexViewModel

@{
    ViewData["Title"] = "Clients";
    ViewData["ActiveNav"] = "Clients";
}

<div class="flex gap-8">
    <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-24">
            <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-4">
                <div class="mb-6 px-2">
                    <p class="text-[11px] text-slate-500 font-medium uppercase tracking-wider">
                        Search and filter
                    </p>
                </div>

                <form asp-controller="Clients" asp-action="Index" method="get" class="space-y-4">
                    <input type="hidden" asp-for="PageSize" />
                    <input type="hidden" name="PageNumber" value="1" />
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                            Search
                        </label>
                        <input asp-for="SearchTerm"
                               class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200"
                               placeholder="Name, code, city, country..." />
                    </div>
                    <button type="submit"
                            class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white text-xs font-bold py-3 rounded-full shadow-lg">
                        Apply Filters
                    </button>
                </form>
            </div>

            @* cards *@
            <div class="grid grid-rows-1 gap-4 mb-8 mt-8">
                <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-100">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-1">
                        Applied filters
                    </span>
                    <div class="text-sm font-semibold text-slate-900 mt-2">
                        @(string.IsNullOrWhiteSpace(Model.SearchTerm) ? "None" : Model.SearchTerm)
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <section class="flex-1 min-w-0">
        @* header *@
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 mb-2">
                    Clients
                </h1>
                <p class="text-sm text-slate-500 max-w-2xl">
                    Browse and manage clients, contact details, and address data.
                </p>
            </div>

            <div class="flex gap-3">
                <a asp-controller="Clients"
                       asp-action="Create"
                       class="px-5 py-2.5 rounded-full bg-blue-600 text-white text-sm font-semibold shadow hover:bg-blue-700 transition">
                    + New Client
                </a>
            </div>
        </div>
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm">
                @successMessage
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm">
                @errorMessage
            </div>
        }
        @* table *@
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
            @* table header *@
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-y border-slate-100">
                            <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Client</th>
                            <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                Contact
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                Address
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                Country
                            </th>
                            <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                Saldo
                            </th>
                            <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    @* table body *@
                    <tbody class="divide-y divide-slate-50">
                        @if (Model.Clients.Any())
                        {
                            @foreach (var client in Model.Clients)
                            {
                                <tr class="hover:bg-slate-100 transition-colors group">
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-4">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-900">
                                                    @client.Name
                                                </div>
                                                <div class="text-[11px] text-slate-400 font-medium">
                                                    @client.ClientCode
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-sm text-slate-700">
                                            @(client.Email ?? "-")
                                        </div>
                                        <div class="text-[11px] text-slate-400">
                                            @(client.PhoneNumber ?? "-")
                                        </div>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-sm text-slate-700">
                                            @(client.AddressLine1 ?? "-")
                                        </div>
                                        <div class="text-sm text-slate-400">
                                            @(client.AddressLine2 ?? "-")
                                        </div>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-sm text-slate-700">
                                            @client.CountryName
                                        </div>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-sm text-slate-700">
                                            @client.Saldo
                                        </div>
                                    </td>

                                    <td class="px-6 py-5 text-right">
                                        <div class="inline-flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <a asp-controller="Clients"
                                                   asp-action="Details"
                                                   asp-route-id="@client.ClientId"
                                                   class="p-2 hover:bg-slate-100 rounded-lg">
                                                <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">Description</span>
                                            </a>

                                            <a asp-controller="Clients"
                                                   asp-action="Edit"
                                                   asp-route-id="@client.ClientId"
                                                   class="p-2 hover:bg-slate-100 rounded-lg">
                                                <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">edit</span>
                                            </a>
                                            @if (client.IsActive)
                                            {
                                                <form asp-controller="Clients"
                                                      asp-action="Deactivate"
                                                      method="post"
                                                      class="inline">
    
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@client.ClientId" />
                                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Clients")" />

                                                    <button type="submit"
                                                            class="p-2 hover:bg-slate-100 rounded-lg group"
                                                            onclick="return confirm('Are you sure you want to deactivate this client?')">
                                                        <span class="material-symbols-outlined text-slate-400 hover:text-red-400">
                                                            Delete
                                                        </span>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-controller="Clients"
                                                      asp-action="Activate"
                                                      method="post"
                                                      class="inline">
    
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@client.ClientId" />
                                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Clients")" />

                                                    <button type="submit"
                                                            class="p-2 hover:bg-slate-100 rounded-lg group"
                                                            onclick="return confirm('Are you sure you want to activate this client?')">
                                                        <span class="material-symbols-outlined text-slate-400 hover:text-green-400">
                                                            restore_from_trash
                                                        </span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-10 text-center text-sm text-slate-400">
                                    No clients found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @* paginator *@
            @await Html.PartialAsync("Partials/_TableFooter", Model.TableFooter)
        </div>
    </section>
</div>