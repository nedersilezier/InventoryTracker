@model InventoryTracker.WebAdmin.ViewModels.Items.CreateEditItemViewModel

@{
    ViewData["Title"] = "Create New Item";
}

<div class="max-w-7xl mx-auto px-4 py-0">
    <div class="mb-1">
        <div class="flex items-center gap-2 text-slate-500 mb-2">
            <a asp-controller="Items"
                   asp-action="Index"
                   class="text-xs font-semibold uppercase tracking-widest hover:text-blue-600 transition-colors">
                Items
            </a>
            <span class="text-sm">›</span>
            <span class="text-xs font-semibold text-black uppercase tracking-widest">
                New Item
            </span>
        </div>
    </div>

    <form asp-controller="Items" asp-action="@GetFormAction()" method="post" class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        @Html.AntiForgeryToken()
        @if (Model.ItemId != null)
        {
            <input type="hidden" asp-for="ItemId" />
        }
        <div class="lg:col-span-8 space-y-6">
            <div class="bg-white rounded-xl p-8 shadow-sm relative overflow-hidden border border-slate-100">
                <div class="absolute top-0 left-0 w-full h-1 bg-blue-600"></div>

                <div class="space-y-8">
                    <h2 class="text-2xl font-bold text-slate-900">
                        Identity &amp; Details
                    </h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label asp-for="Name" class="text-xs font-bold uppercase tracking-wider text-slate-500">Item Name</label>
                            <input asp-for="Name"
                                   class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all placeholder:text-slate-400"
                                   placeholder="e.g. Euro crate" />
                            <span asp-validation-for="Name" class="text-sm text-red-600"></span>
                            <span class="text-[0.7rem] text-slate-400 italic">
                                Required: Primary identification string
                            </span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label asp-for="SKU" class="text-xs font-bold uppercase tracking-wider text-slate-500">SKU</label>
                            <input asp-for="SKU"
                                   class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all placeholder:text-slate-400"
                                   placeholder="e.g. FLW-00-000" />
                            <span asp-validation-for="SKU" class="text-sm text-red-600"></span>
                            <span class="text-[0.7rem] text-slate-400 italic">
                                Required. Must be unique across all warehouses
                            </span>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Description" class="text-xs font-bold uppercase tracking-wider text-slate-500">Description (Optional)</label>
                        <textarea asp-for="Description"
                                  rows="5"
                                  class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all placeholder:text-slate-400 resize-none"
                                  placeholder="Detailed technical specifications and usage guidelines..."></textarea>
                        <span asp-validation-for="Description" class="text-sm text-red-600"></span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-100">
                <h2 class="text-2xl font-bold text-slate-900 mb-8">
                    Metrics &amp; Units
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="flex flex-col gap-2">
                        <label asp-for="UnitOfMeasure" class="text-xs font-bold uppercase tracking-wider text-slate-500">Unit of Measure</label>

                        <div class="relative">
                            <select asp-for="UnitOfMeasure"
                                    class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 appearance-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all cursor-pointer">
                                <option value="pcs">Pieces (pcs)</option>
                                <option value="kg">Kilograms (kg)</option>
                                <option value="m">Meters (m)</option>
                                <option value="l">Liters (l)</option>
                                <option value="unit">Unit</option>
                            </select>
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">⌄</span>
                        </div>

                        <span asp-validation-for="UnitOfMeasure" class="text-sm text-red-600"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="CreditValue" class="text-xs font-bold uppercase tracking-wider text-slate-500">Credit Value</label>
                        <div class="relative">
                            <input asp-for="CreditValue"
                                   type="number"
                                   step="0.01"
                                   min="0"
                                   class="w-full bg-slate-100 border border-transparent rounded-xl pl-4 pr-14 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all"
                                   placeholder="0.00" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">
                                PTS
                            </span>
                        </div>

                        <span asp-validation-for="CreditValue" class="text-sm text-red-600"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Weight" class="text-xs font-bold uppercase tracking-wider text-slate-500">Weight</label>

                        <div class="relative">
                            <input asp-for="Weight"
                                   type="number"
                                   step="0.01"
                                   min="0"
                                   class="w-full bg-slate-100 border border-transparent rounded-xl pl-4 pr-14 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all"
                                   placeholder="0.00" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">
                                KG
                            </span>
                        </div>

                        <span asp-validation-for="Weight" class="text-sm text-red-600"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-4 space-y-6">
            <div class="bg-slate-100 rounded-xl aspect-square flex flex-col items-center justify-center border-2 border-dashed border-slate-300 p-8 text-center">
                <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center mb-4 shadow-sm">
                    <span class="text-blue-600 text-3xl">📷</span>
                </div>
                <h3 class="text-sm font-bold text-slate-900 mb-1">
                    Add Image
                </h3>
                <p class="text-xs text-slate-500">
                    Upload a photo or drawing to help identify the item.
                </p>
            </div>

            <div class="flex flex-col gap-3 pt-2 mb-4">
                <button type="submit"
                        class="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold py-4 rounded-full shadow hover:shadow-lg transition-all flex items-center justify-center gap-2">
                    <span>💾</span>
                    <span>Save Item</span>
                </button>

                <a asp-controller="Items"
                       asp-action="Index"
                       class="w-full bg-slate-200 text-slate-600 font-bold py-4 rounded-full hover:bg-slate-300 transition-all text-center">
                    Cancel
                </a>
            </div>
            <div asp-validation-summary="ModelOnly"
                 class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


@functions {
        private string GetFormAction()
        {
            return Model.ItemId == null ? "Create" : "Edit";
    }
}