<!DOCTYPE html>
<style>
    .bg-surface {
        background: linear-gradient(135deg, #f8f9fa 0%, #eef1f4 100%);
        min-height: 100vh;
        margin: 0;
    }
</style>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - FlowState</title>

    <link href="~/css/site.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-surface text-on-surface">

    @await Html.PartialAsync("_TopNavbar")
    <main class="pt-24 pb-12 px-6 max-w-[1440px] mx-auto">
        @RenderBody()
    </main>

</body>
</html>