@model IEnumerable<InventoryTracker.Contracts.Responses.Transactions.TransactionListDTO>
<style>
    .transactions-card{
        overflow: hidden;
    }
    table {
        width: 100%;
        border-collapse: collapse;
    }
    th, td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }
    th {
        background-color: #f5f5f5;
    }
    .header {
        font-weight: bold;
        background: linear-gradient(0deg, #f5f5f5, #e0e0e0);
    }
</style>
<div class="bg-white rounded-xl shadow transactions-card">
    <div class="header p-3">
        <h2 class="font-bold mb-4">Recent Transactions</h2>
    </div>
    <div class="p-3">
    <table class="w-full">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>From</th>
                <th>To</th>
                <th>Status</th>
                <th>Reference Number</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.TransactionDate</td>
                    <td>@t.TypeDisplay</td>
                    <td>@t.FromDisplay</td>
                    <td>@t.ToDisplay</td>
                    <td>@t.Status</td>
                    <td>@t.ReferenceNumber</td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>