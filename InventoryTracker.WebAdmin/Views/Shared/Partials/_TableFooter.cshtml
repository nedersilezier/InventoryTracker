@model InventoryTracker.WebAdmin.ViewModels.HelperVMs.TableFooterViewModel
<div class="p-6 border-t border-slate-100 flex items-center justify-between">

    <span class="text-xs text-slate-400">
        Showing @Model.DisplayedCount of @Model.TotalCount @Model.EntityName
    </span>
    <div class="flex items-center gap-4">
        <form asp-controller="@Model.Pagination.Controller" asp-action="@Model.Pagination.Action" method="get" class="flex items-center gap-2">
            @{
                foreach (var routeValue in Model.Pagination.RouteValues)
                {
                    if (routeValue.Key != "PageNumber" && routeValue.Key != "PageSize")
                    {
                        <input type="hidden" name="@routeValue.Key" value="@routeValue.Value" />
                    }
                }
            }
            <input type="hidden" name="PageNumber" value="@Model.Pagination.CurrentPage" />

            <label for="pageSize" class="text-xs text-slate-500 font-medium">
                Rows per page
            </label>

            <select id="pageSize"
                    name="PageSize"
                    onchange="this.form.submit()"
                    class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200">
                <option value="5" selected="@(Model.Pagination.PageSize == 5)">5</option>
                <option value="10" selected="@(Model.Pagination.PageSize == 10)">10</option>
                <option value="20" selected="@(Model.Pagination.PageSize == 20)">20</option>
                <option value="50" selected="@(Model.Pagination.PageSize == 50)">50</option>
            </select>
        </form>

        @if (Model.Pagination.TotalPages > 1)
        {
            <div class="flex gap-2">
                @for (var i = 1; i <= Model.Pagination.TotalPages; i++)
                {
                    if (i == Model.Pagination.CurrentPage)
                    {
                        <span class="px-3 py-1 bg-blue-600 text-white rounded-lg text-xs font-bold">
                            @i
                        </span>
                    }
                    else
                    {
                        var routeValues = new Dictionary<string, string?>(Model.Pagination.RouteValues)
                        {
                            ["PageNumber"] = i.ToString()
                        };

                        <a asp-controller="@Model.Pagination.Controller"
                               asp-action="@Model.Pagination.Action"
                               asp-all-route-data="routeValues"
                               class="px-3 py-1 text-slate-500 hover:bg-slate-50 rounded-lg text-xs font-medium">
                            @i
                        </a>
                    }
                }
            </div>
        }
    </div>
</div>