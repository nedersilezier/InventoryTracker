@model InventoryTracker.WebAdmin.ViewModels.Countries.CountriesIndexViewModel
@{
    ViewData["Title"] = "Countries";
}

<div class="flex gap-8">
    <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-24">
            <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-4">
                <div class="mb-6 px-2">
                    <p class="text-[11px] text-slate-500 font-medium uppercase tracking-wider">
                        Search and filter
                    </p>
                </div>

                <form asp-controller="Countries" asp-action="Index" method="get" class="space-y-4">
                    <input type="hidden" asp-for="PageSize" />
                    <input type="hidden" name="PageNumber" value="1" />
                    <div>
                        <label asp-for="SearchTerm"
                               class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">
                            Search
                        </label>

                        <input asp-for="SearchTerm"
                               value="@(ViewContext.HttpContext.Request.Query["SearchTerm"])"
                               class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200"
                               placeholder="Name, code..." />
                    </div>

                    <button type="submit"
                            class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white text-xs font-bold py-3 rounded-full shadow-lg">
                        Apply Filters
                    </button>
                </form>
            
            </div>
            <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-100">
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-1">
                    Applied filters
                </span>
                <div class="text-sm font-semibold text-slate-900 mt-2">
                    @(string.IsNullOrWhiteSpace(Model.SearchTerm) ? "None" : Model.SearchTerm)
                </div>
            </div>
        </div>
    </aside>
    <section class="flex-1 min-w-0">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 mb-2">
                    Countries
                </h1>
                <p class="text-sm text-slate-500 max-w-2xl">
                    Browse and manage countries.
                </p>
            </div>

            <div class="flex gap-3">
                <a asp-controller="Countries"
                       asp-action="Create"
                       class="px-5 py-2.5 rounded-full bg-blue-600 text-white text-sm font-semibold shadow hover:bg-blue-700 transition">
                    + New Country
                </a>
            </div>
        </div>

        <!-- Table -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <colgroup>
                        <col class="w-[14%]" />
                        <col class="w-[24%]" />
                        <col class="w-[11%]" />
                        <col class="w-[24%]" />
                        <col class="w-[11%]" />
                        <col class="w-[16%]" />
                    </colgroup>
                    <thead>
                        <tr class="bg-slate-50 border-y border-slate-100">
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Name / Code</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Created By</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Created At</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Updated By</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Updated At</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-right">Actions</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-50">
                        @if (Model.Countries.Any())
                        {
                            @foreach (var country in Model.Countries)
                            {
                                <tr class="hover:bg-slate-100 transition-colors group">

                                    <!-- Country -->
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-900">
                                                    @country.Name
                                                </div>

                                                <div class="text-[11px] text-slate-400">
                                                    @country.Code
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Created By -->
                                    <td class="px-6 py-5 text-sm font-mono text-slate-500">
                                        @country.CreatedBy
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-[12px] font-medium text-slate-900">
                                            @country.CreatedAt.ToString("yyyy-MM-dd")
                                        </div>
                                        <div class="text-[11px] text-slate-400">
                                            @country.CreatedAt.ToString("HH:mm")
                                        </div>
                                    </td>

                                    <!-- Updated By -->
                                    <td class="px-6 py-5 text-sm font-mono text-slate-500">
                                        @country.UpdatedBy
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="text-[12px] font-medium text-slate-900">
                                            @{
                                                if(country.UpdatedAt.HasValue)
                                                {
                                                    @country.UpdatedAt.Value.ToString("yyyy-MM-dd")
                                                }
                                            }
                                        </div>
                                        <div class="text-[11px] text-slate-400">
                                            @{
                                                if(country.UpdatedAt.HasValue)
                                                {
                                                    @country.UpdatedAt.Value.ToString("HH:mm")
                                                }
                                            }
                                        </div>
                                    </td>

                                    <!-- Actions -->
                                    <td class="px-6 py-5 text-right">
                                        <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">

                                            <a asp-controller="Countries"
                                                   asp-action="Edit"
                                                   asp-route-id="@country.CountryId"
                                                   class="p-2 hover:bg-slate-100 rounded-lg">
                                                <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">edit</span>
                                            </a>
                                            <a asp-controller="Countries"
                                                   asp-action="Delete"
                                                   asp-route-id="@country.CountryId"
                                                   class="p-2 hover:bg-slate-100 rounded-lg">
                                                <span class="material-symbols-outlined text-slate-400 hover:text-red-400">delete</span>
                                            </a>

                                        </div>
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-10 text-center text-sm text-slate-400">
                                    No countries found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

            <!-- Footer -->
            @await Html.PartialAsync("Partials/_TableFooter", Model.TableFooter)
        </div>
    </section>
</div>