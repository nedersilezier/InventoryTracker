@model InventoryTracker.WebAdmin.ViewModels.Countries.CreateEditCountryViewModel

@{
    var isEditMode = Model.CountryId != null;
    ViewData["Title"] = isEditMode ? "Edit Country" : "Create New Country";
}

<div class="max-w-7xl mx-auto px-4 py-0">
    <div class="mb-6">
        <div class="flex items-center gap-2 text-slate-500 mb-2">
            <a asp-controller="Countries"
                   asp-action="Index"
                   class="text-xs font-semibold uppercase tracking-widest hover:text-blue-600 transition-colors">
                Countries
            </a>
            <span class="text-sm">›</span>
            <span class="text-xs font-semibold text-black uppercase tracking-widest">
                @(isEditMode ? "Edit Country" : "New Country")
            </span>
        </div>
    </div>

    <form asp-controller="Countries" asp-action="@GetFormAction()" method="post" class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        @Html.AntiForgeryToken()

        @if (isEditMode)
        {
            <input type="hidden" asp-for="CountryId" />
        }

        <div class="lg:col-span-8 space-y-6">
            <div class="bg-white rounded-xl p-8 shadow-sm relative overflow-hidden border border-slate-100">
                <div class="absolute top-0 left-0 w-full h-1 bg-blue-600"></div>

                <div class="space-y-8">
                    <div>
                        <h2 class="text-2xl font-bold text-slate-900">
                            Country Information
                        </h2>
                        <div class="h-1 w-12 bg-blue-100 mt-3 rounded-full"></div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Name" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                            Country Name
                        </label>
                        <input asp-for="Name"
                               class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-4 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 focus:bg-blue-50/40 transition-all placeholder:text-slate-400"
                               placeholder="e.g. United States" />
                        <span asp-validation-for="Name" class="text-sm text-red-600"></span>
                        <span class="text-[0.7rem] text-slate-400 italic">
                            Required. Used in all address and shipping country selectors.
                        </span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <div class="flex items-center justify-between gap-4">
                            <label asp-for="CountryCode" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                ISO Code
                            </label>
                        </div>

                        <input asp-for="CountryCode"
                               maxlength="3"
                               class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-4 uppercase tracking-wider focus:ring-2 focus:ring-blue-200 focus:border-blue-300 focus:bg-blue-50/40 transition-all placeholder:text-slate-400"
                               placeholder="e.g. USA" />
                        <span asp-validation-for="CountryCode" class="text-sm text-red-600"></span>
                        <span class="text-[0.7rem] text-slate-400 italic">
                            Required. ISO country identifier, for example PL, US, DE.
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-4 flex flex-col h-full">
    
            <div class="mt-auto grid grid-cols-1 gap-3 pt-2 mb-4">
                <button type="submit"
                        class="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold py-4 rounded-full shadow hover:shadow-lg transition-all flex items-center justify-center gap-2">
                    <span>💾</span>
                    <span>Save Country</span>
                </button>

                <a asp-controller="Countries"
                       asp-action="Index"
                       class="w-full bg-slate-200 text-slate-600 font-bold py-4 rounded-full hover:bg-slate-300 transition-all text-center">
                    Cancel
                </a>
            </div>

            <div asp-validation-summary="ModelOnly"
                 class="min-h-[52px] rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700 mt-4">
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@functions {
    private string GetFormAction()
    {
        return Model.CountryId == null ? "Create" : "Edit";
    }
}
