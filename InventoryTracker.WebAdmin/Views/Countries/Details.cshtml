@model InventoryTracker.Contracts.Responses.Countries.CountryResponseDTO
@{
    ViewData["Title"] = "Country Details";
}
<h1>Country Details</h1>
<div>
    <h4>Country</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Id
        </dt>
        <dd class="col-sm-10">
            @Model.CountryId
        </dd>
        <dt class="col-sm-2">
            Name
        </dt>
        <dd class="col-sm-10">
            @Model.Name
        </dd>
        <dt class="col-sm-2">
            Code
        </dt>
        <dd class="col-sm-10">
            @Model.Code
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>