@model InventoryTracker.WebAdmin.ViewModels.Transactions.TransactionFiltersViewModel

<div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-4 sticky top-24">
    <div class="mb-6 px-2">
        <p class="text-[11px] text-slate-500 font-medium uppercase tracking-wider">
            Search and filter
        </p>
    </div>

    <form asp-controller="Transactions" asp-action="Index" method="get" class="space-y-6">
        <input type="hidden" asp-for="PageSize" />
        <input type="hidden" name="PageNumber" value="1" />
        <div class="space-y-2">
            <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                Search
            </label>
            <input asp-for="SearchTerm"
                   class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200"
                   placeholder="Ref, client, warehouse..." />
        </div>

        <div class="space-y-2">
            <label asp-for="DateFrom" class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                Date from
            </label>
            <input asp-for="DateFrom"
                   type="date"
                   id="DateFrom"
                   class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200" />
            <span asp-validation-for="DateFrom" class="text-xs text-red-500"></span>
        </div>

        <div class="space-y-2">
            <label asp-for="DateTo" class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                Date to
            </label>
            <input asp-for="DateTo"
                   type="date"
                   id="DateTo"
                   class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200" />
            <span asp-validation-for="DateTo" class="text-xs text-red-500"></span>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                Transaction Type
            </label>

            <div class="space-y-2">
                <label class="flex items-center gap-2 text-xs text-slate-600">
                    <input asp-for="IncludeAdjustments" class="rounded border-slate-300 text-blue-600 focus:ring-blue-200" />
                    Adjustments
                </label>

                <label class="flex items-center gap-2 text-xs text-slate-600">
                    <input asp-for="IncludeIssues" class="rounded border-slate-300 text-blue-600 focus:ring-blue-200" />
                    Issues
                </label>

                <label class="flex items-center gap-2 text-xs text-slate-600">
                    <input asp-for="IncludeReturns" class="rounded border-slate-300 text-blue-600 focus:ring-blue-200" />
                    Returns
                </label>

                <label class="flex items-center gap-2 text-xs text-slate-600">
                    <input asp-for="IncludeTransfers" class="rounded border-slate-300 text-blue-600 focus:ring-blue-200" />
                    Transfers
                </label>
            </div>
        </div>

        <button type="submit"
                class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white py-3 rounded-full text-sm font-semibold shadow">
            Apply Changes
        </button>
    </form>
</div>