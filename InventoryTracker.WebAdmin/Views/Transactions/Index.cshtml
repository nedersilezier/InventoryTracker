@model InventoryTracker.WebAdmin.ViewModels.Transactions.TransactionsIndexViewModel

@{
    ViewData["Title"] = "Transactions";
    ViewData["ActiveNav"] = "Transactions";
}

<div class="flex gap-8">
    <aside class="hidden lg:block w-64 shrink-0">
        @await Html.PartialAsync("_TransactionsSidebar", Model.Filters)
    </aside>

    <section class="flex-1 min-w-0 space-y-8">
        <div class="flex justify-between items-end">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">
                    Transactions
                </h1>
                <p class="text-sm text-slate-500 mt-1">
                    Manage transactions.
                </p>
            </div>
            <div class="flex gap-3">
                <a asp-controller="Transactions"
                       asp-action="Create"
                       class="px-5 py-2.5 rounded-full bg-blue-600 text-white text-sm font-semibold shadow hover:bg-blue-700 transition">
                    + New Transaction
                </a>
            </div>
        </div>
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm">
                @successMessage
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm">
                @errorMessage
            </div>
        }
        @await Html.PartialAsync("_TransactionsTable.cshtml", Model)
    </section>
</div>
@section Scripts {
    <script src="~/js/transactions.js"></script>
}