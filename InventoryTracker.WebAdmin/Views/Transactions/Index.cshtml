@model InventoryTracker.WebAdmin.ViewModels.Transactions.TransactionsIndexViewModel

@{
    ViewData["Title"] = "Transactions";
    ViewData["ActiveNav"] = "Transactions";
}

<div class="flex gap-8">
    <aside class="hidden lg:block w-64 shrink-0">
        @await Html.PartialAsync("_TransactionsSidebar", Model.Filters)
    </aside>

    <section class="flex-1 min-w-0 space-y-8">
        <div class="flex justify-between items-end">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">
                    Transactions
                </h1>
                <p class="text-sm text-slate-500 mt-1">
                    Manage transactions.
                </p>
            </div>

            <div class="flex gap-3">
                <div class="relative">
                    <details class="group relative">
                        <summary class="list-none cursor-pointer px-5 py-2.5 rounded-full bg-blue-600 text-white text-sm font-semibold shadow hover:bg-blue-700 transition flex items-center gap-2 select-none">
                            <span class="text-base leading-none">+ New Transaction</span>
                        </summary>

                        <div class="absolute right-0 mt-2 w-56 bg-white rounded-2xl border border-slate-200 shadow-lg overflow-hidden z-50">
                            <a asp-controller="Transactions"
                                   asp-action="CreateAdjustment"
                                   class="block px-4 py-3 text-sm text-slate-700 hover:bg-slate-100">
                                Adjustment
                            </a>

                            <a asp-controller="Transactions"
                                   asp-action="CreateReturn"
                                   class="block px-4 py-3 text-sm text-slate-700 hover:bg-slate-100">
                                Inbound
                            </a>

                            <a asp-controller="Transactions"
                                   asp-action="CreateIssue"
                                   class="block px-4 py-3 text-sm text-slate-700 hover:bg-slate-100">
                                Outbound
                            </a>

                            <a asp-controller="Transactions"
                                   asp-action="CreateTransfer"
                                   class="block px-4 py-3 text-sm text-slate-700 hover:bg-slate-100">
                                Transfer
                            </a>
                        </div>
                    </details>
                </div>
            </div>

        </div>
        @await Html.PartialAsync("_TransactionsTable.cshtml", Model)
    </section>
</div>