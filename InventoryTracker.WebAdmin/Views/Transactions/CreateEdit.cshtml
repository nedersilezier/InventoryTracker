@using InventoryTracker.Shared.Enums
@using System.Text.Json
@model InventoryTracker.WebAdmin.ViewModels.Transactions.CreateEditTransactionViewModel

@{
    ViewData["Title"] = Model.TransactionId == null ? "Add New Transaction" : "Edit Transaction";
    var selectedItems = Model.SelectedItems ?? [];
}
<div class="max-w-7xl mx-auto px-4 py-0">
    <div class="mb-6">
        <div class="flex items-center gap-2 text-slate-500 mb-2">
            <a asp-controller="Transactions"
                   asp-action="Index"
                   class="text-xs font-semibold uppercase tracking-widest hover:text-blue-600 transition-colors">
                Transactions
            </a>
            <span class="text-sm">›</span>
            <span class="text-xs font-semibold text-black uppercase tracking-widest">
                @(Model.TransactionId == null ? "New Transaction" : "Edit Transaction")
            </span>
        </div>
    </div>

    <form asp-controller="Transactions" asp-action="@GetFormAction()" method="post" class="space-y-8" id="transactionForm">
        @Html.AntiForgeryToken()
        @if (Model.TransactionId != null)
        {
            <input type="hidden" asp-for="TransactionId" />
        }
        <div class="bg-white rounded-xl p-8 shadow-sm relative overflow-hidden border border-slate-100">
            <div class="absolute top-0 left-0 w-full h-1 bg-blue-600"></div>
            <div class="space-y-10">
                <section class="space-y-6">
                    <div class="flex items-center gap-4">
                        <span class="bg-blue-100 text-blue-700 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold">
                            01
                        </span>
                        <h2 class="text-sm font-bold uppercase tracking-widest text-slate-500">
                            General Information
                        </h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-6">
                        <div class="flex flex-col gap-2">
                            <label asp-for="Type" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Transaction Type
                            </label>
                            <div class="relative">
                                <select asp-for="Type"
                                        asp-items="Model.AvailableTypes"
                                        id="transactionType"
                                        class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 appearance-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all cursor-pointer">
                                </select>
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">⌄</span>
                            </div>
                            <span asp-validation-for="Type" class="text-sm text-red-600"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label asp-for="TransactionDate" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Transaction Date
                            </label>
                            <input asp-for="TransactionDate"
                                   type="date"
                                   id="transactionDate"
                                   value="@Model.TransactionDate.ToString("yyyy-MM-dd")"
                                   class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all" />
                            <span asp-validation-for="TransactionDate" class="text-sm text-red-600"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label asp-for="ReferenceNumber" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Reference Number
                            </label>
                            <input asp-for="ReferenceNumber"
                                   class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all placeholder:text-slate-400"
                                   placeholder="TXN-9402" />
                            <span asp-validation-for="ReferenceNumber" class="text-sm text-red-600"></span>
                        </div>

                        <div class="md:col-span-3 flex flex-col gap-2">
                            <label asp-for="Notes" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Notes
                            </label>
                            <textarea asp-for="Notes"
                                      rows="3"
                                      class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all placeholder:text-slate-400 resize-none"
                                      placeholder="Enter additional transaction details..."></textarea>
                            <span asp-validation-for="Notes" class="text-sm text-red-600"></span>
                        </div>
                    </div>
                </section>

                <section class="space-y-6">
                    <div class="flex items-center gap-4">
                        <span class="bg-blue-100 text-blue-700 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold">
                            02
                        </span>
                        <h2 class="text-sm font-bold uppercase tracking-widest text-slate-500">
                            Source &amp; Destination
                        </h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                        <div class="flex flex-col gap-2 field-client" data-field="client">
                            <label asp-for="ClientId" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Client
                            </label>
                            <div class="relative">
                                <select asp-for="ClientId"
                                        asp-items="Model.AvailableClients"
                                        id="clientId"
                                        class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 appearance-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all cursor-pointer">
                                    <option value="">Select Client</option>
                                </select>
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">⌄</span>
                            </div>
                            <span asp-validation-for="ClientId" class="text-sm text-red-600"></span>
                        </div>

                        <div class="flex flex-col gap-2 field-sourceWarehouse" data-field="sourceWarehouse">
                            <label asp-for="SourceWarehouseId" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Source Warehouse
                            </label>
                            <div class="relative">
                                <select asp-for="SourceWarehouseId"
                                        asp-items="Model.AvailableWarehouses"
                                        id="sourceWarehouseId"
                                        class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 appearance-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all cursor-pointer">
                                    <option value="">Select Warehouse</option>
                                </select>
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">⌄</span>
                            </div>
                            <span asp-validation-for="SourceWarehouseId" class="text-sm text-red-600"></span>
                        </div>

                        <div class="flex flex-col gap-2 field-destinationWarehouse" data-field="destinationWarehouse">
                            <label asp-for="DestinationWarehouseId" class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                Destination Warehouse
                            </label>
                            <div class="relative">
                                <select asp-for="DestinationWarehouseId"
                                        asp-items="Model.AvailableWarehouses"
                                        id="destinationWarehouseId"
                                        class="w-full bg-slate-100 border border-transparent rounded-xl px-4 py-3 appearance-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all cursor-pointer">
                                    <option value="">Select Warehouse</option>
                                </select>
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">⌄</span>
                            </div>
                            <span asp-validation-for="DestinationWarehouseId" class="text-sm text-red-600"></span>
                        </div>

                        <div id="adjustmentHelp" class="hidden md:col-span-1 flex items-end">
                            <div class="w-full rounded-xl bg-blue-50 border border-blue-100 px-4 py-3 flex gap-3">
                                <span class="material-symbols-outlined text-blue-600 text-xl">info</span>
                                <p class="text-sm text-blue-800 leading-snug">
                                    <span class="font-bold block">Adjustment logic:</span>
                                    Positive = increase stock, Negative = decrease stock
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="space-y-6">
                    <div class="flex items-center gap-4">
                        <span class="bg-blue-100 text-blue-700 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold">
                            03
                        </span>
                        <h2 class="text-sm font-bold uppercase tracking-widest text-slate-500">
                            Transaction Items
                        </h2>
                    </div>

                    <div class="overflow-x-auto rounded-xl bg-slate-50 border border-slate-100">
                        <table class="w-full text-left">
                            <thead>
                                <tr>
                                    <td class="px-4 py-5">
                                        <div class="relative">
                                            <select id="itemToAdd"
                                                    class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 appearance-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all cursor-pointer">
                                                <option value="">Select item to add...</option>
                                                @foreach (var item in Model.AvailableItems)
                                                {
                                                    <option value="@item.Value" data-uom="@item.UnitOfMeasure">@item.Text</option>
                                                }
                                            </select>
                                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">⌄</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-5">
                                        <input id="quantityToAdd"
                                               type="number"
                                               step="0.01"
                                               class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-center font-bold focus:ring-2 focus:ring-blue-200 focus:border-blue-300 transition-all"
                                               placeholder="0" />
                                    </td>
                                    <td class="px-4 py-5 text-right">
                                        <button type="button"
                                                id="addItemButton"
                                                class="inline-flex items-center justify-center w-12 h-12 bg-blue-600 text-white rounded-xl shadow hover:shadow-lg hover:bg-blue-700 transition-all active:scale-95">
                                            <span class="material-symbols-outlined">add</span>
                                        </button>
                                    </td>
                                </tr>
                                <tr class="border-b border-slate-200">
                                    <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">Item</th>
                                    <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest w-40">Quantity</th>
                                    <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest w-24 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody id="selectedItemsTableBody" class="divide-y divide-slate-200">
                            </tbody>
                            <tbody class="hidden">
                                <tr>
                                    <td colspan="3">
                                        <div id="selectedItemsInputs"></div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <p class="text-sm text-slate-500">
                        Add at least one item before submitting the transaction.
                    </p>
                    <p id="itemsClientError" class="hidden text-sm text-red-600"></p>
                </section>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-8">
                <div asp-validation-summary="ModelOnly"
                     class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700 min-h-[52px]">
                </div>
            </div>

            <div class="lg:col-span-4 grid grid-cols-1 lg:grid-cols-4 gap-4">
                <div class="lg:col-span-2 space-y-3">
                    <button type="button"
                            onclick="window.close(); setTimeout(() => window.location.href='@Url.Action("Index", "Transactions")', 150);"
                            class="w-full bg-slate-200 text-slate-600 font-bold py-4 rounded-full hover:bg-slate-300 transition-all text-center block">
                        Cancel
                    </button>
                </div>

                <div class="lg:col-span-2 space-y-3">
                    <button type="submit"
                            class="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold py-4 rounded-full shadow hover:shadow-lg transition-all flex items-center justify-center gap-2">
                        <span>💾</span>
                        <span>Save Transaction</span>
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
@functions {
    private string GetFormAction()
    {
        return Model.TransactionId == null ? "Create" : "Edit";
    }
}
@section Scripts {
    <script>
        (() => {
            // Get the main form element.
            const transactionForm = document.getElementById('transactionForm');

            // Get transaction type select
            const transactionType = document.getElementById('transactionType');

            // Get item quantity input
            const quantityToAdd = document.getElementById('quantityToAdd');

            // Get item select
            const itemToAdd = document.getElementById('itemToAdd');

            // Get the button that adds an item to the local selectedItems array.
            const addItemButton = document.getElementById('addItemButton');

            // Get the adjustment help box. Visible only for Adjustment transactions.
            const adjustmentHelp = document.getElementById('adjustmentHelp');

            // Get selected items table body
            const tableBody = document.getElementById('selectedItemsTableBody');

            // Get container with hidden inputs
            const hiddenInputs = document.getElementById('selectedItemsInputs');

            // Get client-side error paragraph for item-related messages.
            const itemsClientError = document.getElementById('itemsClientError');

            // Get source and destination warehouse selects.
            const sourceWarehouse = document.getElementById('sourceWarehouseId');
            const destinationWarehouse = document.getElementById('destinationWarehouseId');

            // Load selected items from the Razor model into JavaScript.
            // This allows the page to keep items if the server returns the view with existing data.
            const selectedItems = @Html.Raw(JsonSerializer.Serialize(selectedItems));

            // Map logical field names to their HTML containers.
            // These containers are shown or hidden depending on transaction type.
            const fieldContainers = {
                client: document.querySelector('[data-field="client"]'),
                sourceWarehouse: document.querySelector('[data-field="sourceWarehouse"]'),
                destinationWarehouse: document.querySelector('[data-field="destinationWarehouse"]')
            };

            // Update quantity input behavior when selected item changes. Depends on items unit of measure
            itemToAdd.addEventListener('change', () => {
                // Get currently selected option from the item select.
                const selected = itemToAdd.options[itemToAdd.selectedIndex];

                // Read unit of measure from data-uom attribute.
                const uom = selected.dataset.uom;

                // For weight/liquid units allow decimals.
                if (uom === 'kg' || uom === 'l') {
                    quantityToAdd.step = '0.01';
                    quantityToAdd.dataset.integerOnly = 'false';
                }
                // For other units, for example pcs, allow only whole numbers.
                else {
                    quantityToAdd.step = '1';
                    quantityToAdd.dataset.integerOnly = 'true';
                }
            });

            // Prevent typing decimal separators when current item requires whole numbers.
            quantityToAdd.addEventListener('keydown', (e) => {
                // Check if the selected item should only allow integers.
                if (quantityToAdd.dataset.integerOnly === 'true') {
                    // Block dot and comma.
                    if (e.key === '.' || e.key === ',') {
                        e.preventDefault();
                    }
                }
            });

            function setFieldOrder(type) {
                Object.values(fieldContainers).forEach(container => {
                    if (!container) return;
                    container.classList.remove('md:order-1', 'md:order-2', 'md:order-3');
                });

                if (type === 'IssueToClient') {
                    fieldContainers.sourceWarehouse?.classList.add('md:order-1');
                    fieldContainers.client?.classList.add('md:order-2');
                } else if (type === 'ReturnFromClient') {
                    fieldContainers.client?.classList.add('md:order-1');
                    fieldContainers.destinationWarehouse?.classList.add('md:order-2');
                } else if (type === 'TransferBetweenWarehouses') {
                    fieldContainers.sourceWarehouse?.classList.add('md:order-1');
                    fieldContainers.destinationWarehouse?.classList.add('md:order-2');
                }
            }

            // Show or hide a form field by logical name.
            function showField(name, visible) {
                // Get the container from fieldContainers map.
                const container = fieldContainers[name];

                // Do nothing if the field does not exist.
                if (!container) return;

                // Toggle Tailwind hidden class.
                container.classList.toggle('hidden', !visible);

                // Find the first input/select/textarea inside this field.
                const input = container.querySelector('select, input, textarea');

                // Do nothing if there is no input inside.
                if (!input) return;

                // Disabled fields are not submitted with the form.
                input.disabled = !visible;

                // Clear hidden field value to avoid sending stale data.
                if (!visible) {
                    input.value = '';
                }
            }

            // Apply UI rules based on selected transaction type.
            function applyTypeView() {
                // Read currently selected transaction type.
                const type = transactionType.value;

                // Client is needed for issue to client and return from client.
                showField('client', type === 'IssueToClient' || type === 'ReturnFromClient');

                // Source warehouse is needed for issue, transfer and adjustment.
                showField('sourceWarehouse',
                    type === 'IssueToClient' ||
                    type === 'TransferBetweenWarehouses' ||
                    type === 'Adjustment'
                );

                // Destination warehouse is needed for return and transfer.
                showField('destinationWarehouse',
                    type === 'ReturnFromClient' ||
                    type === 'TransferBetweenWarehouses'
                );
                // set select fields order depending on type
                setFieldOrder(type);
                // Show adjustment help text only for adjustment transaction.
                adjustmentHelp?.classList.toggle('hidden', type !== 'Adjustment');

                // Change quantity placeholder for adjustment because negative values are allowed there.
                if (quantityToAdd) {
                    quantityToAdd.placeholder = type === 'Adjustment' ? 'e.g. -5' : '0';
                }
                // Re-sync warehouses after transaction type changes.
                syncWarehouses();
            }

            // Show item-related client-side error.
            function showItemsError(message) {
                itemsClientError.textContent = message;
                itemsClientError.classList.remove('hidden');
            }

            // Hide and clear item-related client-side error.
            function clearItemsError() {
                itemsClientError.textContent = '';
                itemsClientError.classList.add('hidden');
            }

            // Normalize item shape because C# JSON can produce PascalCase properties.
            function normalizeItem(item) {
                return {
                    itemId: String(item.itemId ?? item.ItemId ?? ''),
                    name: String(item.name ?? item.Name ?? ''),
                    quantity: Number(item.quantity ?? item.Quantity ?? 0)
                };
            }

            // Create hidden input for MVC model binding.
            function createHiddenInput(name, value) {
                const input = document.createElement('input');

                input.type = 'hidden';
                input.name = name;
                input.value = value;

                return input;
            }

            // Render selected items table and matching hidden inputs.
            function renderItems() {
                // Clear current table rows.
                tableBody.innerHTML = '';

                syncSelectedItemsInputs();

                // Show empty state if no items are selected.
                if (selectedItems.length === 0) {
                    const row = document.createElement('tr');
                    const cell = document.createElement('td');

                    cell.colSpan = 3;
                    cell.className = 'px-4 py-8 text-center text-sm text-slate-400';
                    cell.textContent = 'No items added yet.';

                    row.appendChild(cell);
                    tableBody.appendChild(row);

                    return;
                }

                // Render every selected item.
                selectedItems.forEach((item, index) => {
                    // Create table row.
                    const row = document.createElement('tr');

                    // Create item name cell.
                    const itemCell = document.createElement('td');
                    itemCell.className = 'px-4 py-4';

                    // Create item name text.
                    const itemName = document.createElement('div');
                    itemName.className = 'font-bold text-slate-900';
                    itemName.textContent = item.name;

                    itemCell.appendChild(itemName);

                    // Create quantity cell.
                    const quantityCell = document.createElement('td');
                    quantityCell.className = 'px-4 py-4';

                    // Create visual quantity badge.
                    const quantityBadge = document.createElement('span');
                    quantityBadge.className = 'inline-flex items-center px-3 py-1 bg-slate-200 rounded-full text-sm font-bold text-slate-800';
                    quantityBadge.textContent = item.quantity;

                    quantityCell.appendChild(quantityBadge);

                    // Create action cell.
                    const actionCell = document.createElement('td');
                    actionCell.className = 'px-4 py-4 text-right';

                    // Create remove button.
                    const removeButton = document.createElement('button');
                    removeButton.type = 'button';
                    removeButton.className = 'p-2 text-red-600 hover:bg-red-50 rounded-full transition-all';
                    removeButton.innerHTML = '<span class="material-symbols-outlined text-xl">delete</span>';

                    // Remove item from selectedItems array and re-render table.
                    removeButton.addEventListener('click', () => {
                        selectedItems.splice(index, 1);
                        clearItemsError();
                        renderItems();
                    });

                    actionCell.appendChild(removeButton);

                    // Add all cells to the row.
                    row.appendChild(itemCell);
                    row.appendChild(quantityCell);
                    row.appendChild(actionCell);

                    // Add row to the table.
                    tableBody.appendChild(row);
                });
            }

            // Add currently selected item to selectedItems array.
            function addItem() {
                // Read item id from select.
                const itemId = itemToAdd.value;

                // Read item name from selected option text.
                const itemName = itemToAdd.options[itemToAdd.selectedIndex]?.text ?? '';

                // Convert quantity input value to number.
                const quantity = Number(quantityToAdd.value);

                // Require item selection.
                if (!itemId) {
                    showItemsError('Select an item before adding it.');
                    return;
                }

                // Require non-zero quantity.
                if (!quantity || quantity === 0) {
                    showItemsError('Quantity cannot be 0.');
                    return;
                }

                // Find if this item already exists in selectedItems.
                const existingItem = selectedItems.find(x => x.itemId === itemId);

                // If item exists, add quantity to existing row.
                if (existingItem) {
                    const type = transactionType.value;
                    let quantityDifference = existingItem.quantity + quantity;
                    // Let only adjustments be negative
                    if(type !== "Adjustment" && quantityDifference < 0)
                    {
                        showItemsError('Quantity cannot be negative.');
                        return;
                    }
                    existingItem.quantity = quantityDifference;
                }
                // Otherwise add a new row.
                else {
                    selectedItems.push({ itemId, name: itemName, quantity });
                }

                // Clear add-item controls after successful add.
                itemToAdd.value = '';
                quantityToAdd.value = '';

                // Clear possible error and update table.
                clearItemsError();
                renderItems();
            }

            // Normalize selectedItems loaded from server before using them in JS.
            for (let i = 0; i < selectedItems.length; i++) {
                selectedItems[i] = normalizeItem(selectedItems[i]);
            }

            // Prevent selecting the same warehouse as source and destination during transfer.
            function syncWarehouses() {
                // Read current transaction type.
                const type = transactionType.value;

                // Enable all options first, because selected values may have changed.
                [...destinationWarehouse.options].forEach(opt => opt.disabled = false);
                [...sourceWarehouse.options].forEach(opt => opt.disabled = false);

                // This rule only applies to warehouse transfer.
                if (type !== 'TransferBetweenWarehouses') return;

                // Read selected source and destination values.
                const sourceValue = sourceWarehouse.value;
                const destinationValue = destinationWarehouse.value;

                // In destination select, disable the warehouse selected as source.
                [...destinationWarehouse.options].forEach(opt => {
                    if (opt.value && opt.value === sourceValue) {
                        opt.disabled = true;
                    }
                });

                // In source select, disable the warehouse selected as destination.
                [...sourceWarehouse.options].forEach(opt => {
                    if (opt.value && opt.value === destinationValue) {
                        opt.disabled = true;
                    }
                });

                // If both selects somehow have the same value, clear destination.
                if (sourceValue && sourceValue === destinationValue) {
                    destinationWarehouse.value = '';
                }
            }

            // Add hidden inputs so ASP.NET MVC can bind SelectedItems on submit.
            function syncSelectedItemsInputs() {
                hiddenInputs.innerHTML = '';

                selectedItems.forEach((item, index) => {
                    hiddenInputs.appendChild(createHiddenInput(`SelectedItems[${index}].ItemId`, item.itemId));
                    hiddenInputs.appendChild(createHiddenInput(`SelectedItems[${index}].Name`, item.name));
                    hiddenInputs.appendChild(createHiddenInput(`SelectedItems[${index}].Quantity`, item.quantity));
                });
            }

            // Re-sync warehouse options when source warehouse changes.
            sourceWarehouse?.addEventListener('change', syncWarehouses);

            // Re-sync warehouse options when destination warehouse changes.
            destinationWarehouse?.addEventListener('change', syncWarehouses);

            // Apply transaction type UI rules when transaction type changes.
            transactionType?.addEventListener('change', applyTypeView);

            // Add selected item when add button is clicked.
            addItemButton?.addEventListener('click', addItem);

            // // Before form submit, re-render hidden inputs with the latest selectedItems.
            // transactionForm?.addEventListener('submit', renderItems);
            transactionForm?.addEventListener('submit', () => {
                syncSelectedItemsInputs();
            });
            // Initialize item unit behavior on page load.
            itemToAdd.dispatchEvent(new Event('change'));

            // Initialize transaction-type dependent UI on page load.
            applyTypeView();

            // Initialize selected items table on page load.
            renderItems();
        })();
    </script>
}