@using InventoryTracker.Shared.Enums
@model InventoryTracker.WebAdmin.ViewModels.Transactions.TransactionsIndexViewModel

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <colgroup>
                <col class="w-[12%]" />
                <col class="w-[9%]" />
                <col class="w-[23%]" />
                <col class="w-[23%]" />
                <col class="w-[14%]" />
                <col class="w-[9%]" />
                <col class="w-[10%]" />
            </colgroup>
            <thead>
                <tr class="bg-slate-50 border-y border-slate-100">
                    <th class="py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-500">Date & Time</th>
                    <th class="py-4 px-8 text-[10px] font-bold uppercase tracking-widest text-slate-500">Type</th>
                    <th class="py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-500">From</th>
                    <th class="py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-500">To</th>
                    <th class="py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-500">Reference No</th>
                    <th class="py-4 px-8 text-[10px] font-bold uppercase tracking-widest text-slate-500">Status</th>
                    <th class="py-4 px-6 text-right text-[10px] font-bold uppercase tracking-widest text-slate-500">Actions</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-slate-50">
                @if (Model.Transactions.Any())
                {
                    @foreach (var t in Model.Transactions)
                    {
                        <tr class="hover:bg-slate-100 transition-colors group">
                            <td class="py-4 px-6">
                                <p class="text-[12px] font-medium text-slate-900">
                                    @t.TransactionDate.ToLocalTime().ToString("dd-MM-yyyy")
                                </p>
                                <p class="text-[11px] text-slate-400">
                                    @t.TransactionDate.ToLocalTime().ToString("HH:mm")
                                </p>
                            </td>

                            <td class="py-4 px-6">
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider @GetTypeBadgeClass(t.Type)">
                                    @t.TypeDisplay
                                </span>
                            </td>

                            <td class="py-4 px-6">
                                <div class="text-sm font-semibold text-slate-700">
                                    @t.FromDisplay
                                </div>
                            </td>

                            <td class="py-4 px-6">
                                <div class="text-sm font-semibold text-slate-700">
                                    @t.ToDisplay
                                </div>
                            </td>
                            
                            <td class="py-4 px-6 text-xs font-semibold text-slate-900">
                                @t.ReferenceNumber
                            </td>

                            <td class="py-4 px-6 text-xs font-semibold text-slate-900">
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider @GetStatusBadgeClass(t.Status)">
                                    @t.Status
                                </span>
                            </td>

                            <td class="py-4 px-6 text-right">
                                    <details class="opacity-0 group-hover:opacity-100 transition-opacity relative transaction-actions" data-transaction-actions>
                                        <summary class="list-none cursor-pointer px-3 py-1 rounded-full bg-slate-50 text-black text-sm font-semibold shadow hover:bg-slate-200 transition flex justify-center gap-2 select-none" data-transaction-actions-toggle>
                                            <span class="text-base leading-none text-center hover:text-blue-400">Manage</span>
                                        </summary>
                                        <div class="w-40 bg-white rounded-2xl border border-slate-200 shadow-lg overflow-hidden transaction-actions-menu" data-transaction-actions-menu>
                                            <form asp-controller="Transactions"
                                                  asp-action="Edit"
                                                  method="get"
                                                  target="_blank"
                                                  class="block w-full">
    
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@t.TransactionId" />
                                                <button type="submit"
                                                        class="w-full p-2 hover:bg-slate-100 rounded-lg group">
                                                    <div class="flex items-center justify-end gap-1">
                                                        <div class="material-symbols-outlined text-[18px] text-blue-600">
                                                            edit
                                                        </div>
                                                        <div>
                                                            Edit
                                                        </div>
                                                    </div>
                                                    
                                                </button>
                                            </form>
                                            <form asp-controller="Transactions"
                                                  asp-action="Approve"
                                                  method="post"
                                                  class="block w-full">
    
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@t.TransactionId" />
                                                <button type="submit"
                                                        class="w-full p-2 hover:bg-slate-100 rounded-lg group"
                                                        onclick="return confirm('Are you sure you want to approve this transaction?')">
                                                    <div class="flex items-center justify-end gap-1">
                                                        <div class="material-symbols-outlined text-[18px] text-green-600">
                                                            Check
                                                        </div>
                                                        <div>
                                                            Approve
                                                        </div>
                                                    </div>
                                                    
                                                </button>
                                            </form>
                                            <form asp-controller="Transactions"
                                                  asp-action="Cancel"
                                                  method="post"
                                                  class="block w-full">
    
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@t.TransactionId" />
                                                <button type="submit"
                                                        class="w-full p-2 hover:bg-slate-100 rounded-lg group"
                                                        onclick="return confirm('Are you sure you want to approve this transaction?')">
                                                    <div class="flex items-center justify-end gap-1">
                                                        <div class="material-symbols-outlined text-[18px] text-red-600">
                                                            cancel
                                                        </div>
                                                        <div>
                                                            Cancel
                                                        </div>
                                                    </div>
                                                    
                                                </button>
                                            </form>
                                            <form asp-controller="Transactions"
                                                  asp-action="ShowDocument"
                                                  method="get"
                                                  class="block w-full">
    
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@t.TransactionId" />
                                                <button type="submit"
                                                        class="w-full p-2 hover:bg-slate-100 rounded-lg group">
                                                    <div class="flex items-center justify-end gap-1">
                                                        <div class="material-symbols-outlined text-[18px] text-slate-600">
                                                            article
                                                        </div>
                                                        <div>
                                                            Document
                                                        </div>
                                                    </div>
                                                </button>
                                            </form>
                                        </div>
                                    </details>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="px-6 py-10 text-center text-sm text-slate-400">
                            No transactions found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- Footer -->
    @await Html.PartialAsync("Partials/_TableFooter", Model.TableFooter)
</div>
@functions {
    private string GetTypeBadgeClass(TransactionType type)
    {
        switch (type)
        {
            case TransactionType.ReturnFromClient:
                return "bg-blue-50 text-blue-700";
            case TransactionType.IssueToClient:
                return "bg-red-50 text-blue-700";
            case TransactionType.TransferBetweenWarehouses:
                return "bg-slate-100 text-slate-600";
            case TransactionType.Adjustment:
                return "bg-amber-50 text-amber-700";
            default:
                return "";
        }
    }
    private string GetStatusBadgeClass(TransactionStatus status)
    {
        switch (status)
        {
            case TransactionStatus.Approved:
                return "bg-emerald-50 text-emerald-700";
            case TransactionStatus.Draft:
                return "bg-blue-50 text-blue-700";
            case TransactionStatus.Cancelled:
                return "bg-red-50 text-red-700";
            default:
                return "bg-slate-100 text-slate-600";
        }
    }
}