@model InventoryTracker.WebAdmin.ViewModels.Stocks.StocksIndexViewModel

<div class="flex gap-8">
    <aside class="hidden lg:block w-64 shrink-0">
        <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-4 sticky top-24">
            <div class="mb-6 px-2">
                <p class="text-[11px] text-slate-500 font-medium uppercase tracking-wider">
                    Search and filter -- @Model.PageSize
                </p>
            </div>

            <form asp-controller="Stocks" asp-action="Index" method="get" class="space-y-6">
                <input type="hidden" asp-for="PageSize" />
                <input type="hidden" name="PageNumber" value="1" />
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                        Search
                    </label>
                    <input asp-for="SearchTerm"
                           class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200"
                           placeholder="Ref, client, warehouse..." />
                </div>
                <div class="space-y-2">
                    <label asp-for="SelectedWarehouseId"
                           class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">
                        Warehouse
                    </label>

                    <select asp-for="SelectedWarehouseId"
                            asp-items="Model.Warehouses"
                            class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200">
                    </select>
                </div>
                <button type="submit"
                        class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white text-xs font-bold py-3 rounded-full shadow-lg">
                    Apply Filters
                </button>
            </form>
        </div>
    </aside>
    <section class="flex-1 min-w-0">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 mb-2">
                    Stocks
                </h1>
                <p class="text-sm text-slate-500 max-w-2xl">
                    Browse stocks.
                </p>
            </div>
        </div>

        <!-- Table -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <colgroup>
                        <col class="w-[30%]" />
                        <col class="w-[30%]" />
                        <col class="w-[15%]" />
                        <col class="w-[25%]" />
                    </colgroup>
                    <thead>
                        <tr class="bg-slate-50 border-y border-slate-100">
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Item name</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Warehouse</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Unit of Measure</th>
                            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Quantity</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-50">
                        @if (Model.Stocks.Any())
                        {
                            @foreach (var stock in Model.Stocks)
                            {
                                <tr class="hover:bg-slate-100 transition-colors group">
                                    @* Stock *@
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-900">
                                                    @stock.ItemName
                                                </div>
                                                <div class="text-[11px] text-slate-400">
                                                    @stock.SKU
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Warehouse -->
                                    <td class="px-6 py-5 text-sm text-slate-700">
                                        @stock.WarehouseName
                                    </td>

                                    <!-- Unit ofmeasure -->
                                    <td class="px-6 py-5 text-sm text-slate-900">
                                        @stock.UnitOfMeasure
                                    </td>

                                    <!-- Quantity -->
                                    <td class="px-6 py-5 text-sm font-medium text-slate-900">
                                        @stock.Quantity
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-10 text-center text-sm text-slate-400">
                                    No stocks found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

            <!-- Footer -->
            @await Html.PartialAsync("Partials/_TableFooter", Model.TableFooter)
        </div>
    </section>
</div>