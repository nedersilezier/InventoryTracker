@model InventoryTracker.WebOperator.ViewModels.Transactions.TransactionCardViewModel
@using InventoryTracker.Shared.Enums

<div class="group bg-white rounded-xl p-4 flex flex-col border-l-4 @GetBorderClass(Model.Type) hover:shadow-md transition h-full">

    <!-- HEADER -->
    <div class="flex justify-between items-start gap-2">
        <span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold mb-1 mr-5 @GetBadgeClass(Model.Type)">
                @Model.TypeDisplay
            </span>

            <h3 class="text-sm font-bold text-slate-900 truncate mt-4">
                Ref: @Model.ReferenceNumber
            </h3>
        </span>

        <span class="text-[11px] text-bold text-black whitespace-nowrap">
            @Model.TransactionDate.ToLocalTime().ToString("dd-MM-yyyy")
            <span class="text-[10px] text-slate-600 whitespace-nowrap ml-2">@Model.TransactionDate.ToLocalTime().ToString("HH:mm")</span>
        </span>
    </div>

    <!-- BODY -->
    <div class="flex-1 text-sm pb-2 mt-4">

        <!-- ROUTE -->
        <div class="flex items-center justify-between text-slate-700 text-xs font-medium">
            <span class="truncate max-w-[40%]">
                @(string.IsNullOrWhiteSpace(Model.FromDisplay) ? "" : Model.FromDisplay)
            </span>

            <span class="truncate max-w-[40%] text-right">
                @(string.IsNullOrWhiteSpace(Model.ToDisplay) ? "" : Model.ToDisplay)
            </span>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="flex items-center justify-between pt-3 mt-2 border-t">

        <div class="flex gap-1">
            @if (Model.Status == TransactionStatus.Draft)
            {
                <form asp-controller="Transactions"
                      asp-action="Cancel"
                      method="post"
                      class="inline">
    
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="id" value="@Model.TransactionId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                    <button type="submit"
                            onclick="return confirm('Are you sure you want to cancel this transaction?')">
                        <span class="w-8 h-8 flex items-center justify-center rounded hover:bg-red-100 text-slate-500 hover:text-red-600">
                            🗑
                        </span>
                    </button>
                </form>
                <form asp-controller="Transactions"
                      asp-action="Edit"
                      method="get"
                      class="inline">
    
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="id" value="@Model.TransactionId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                    <button type="submit">
                        <span class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 text-slate-500">
                            ✏
                        </span>
                    </button>
                </form>
            }
            else
            {
                <a asp-action="Details"
                       asp-route-id="@Model.TransactionId"
                       class="w-8 h-8 flex items-center justify-center rounded hover:bg-slate-100 text-slate-500">
                    👁
                </a>
            }
        </div>
        <!-- STATUS -->
        <div>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @GetStatusBadgeClass(Model.Status)">
                @Model.StatusDisplay
            </span>
        </div>
    </div>

</div>

@functions {
    private string GetBorderClass(TransactionType type) => type switch
    {
        TransactionType.ReturnFromClient => "border-green-600",
        TransactionType.IssueToClient => "border-red-600",
        TransactionType.TransferBetweenWarehouses => "border-slate-600",
        TransactionType.Adjustment => "border-blue-500",
        _ => "border-slate-300"
    };

    private string GetBadgeClass(TransactionType type) => type switch
    {
        TransactionType.ReturnFromClient => "bg-green-100 text-green-700",
        TransactionType.IssueToClient => "bg-orange-100 text-red-700",
        TransactionType.TransferBetweenWarehouses => "bg-slate-100 text-slate-700",
        TransactionType.Adjustment => "bg-blue-200 text-blue-700",
        _ => "bg-slate-100 text-slate-600"
    };

    private string GetButtonClass(TransactionType type)
    {
        return "bg-blue-700 text-white";
    }

    private string GetStatusBadgeClass(TransactionStatus status) => status switch
    {
        TransactionStatus.Draft => "bg-slate-100 text-slate-700",
        TransactionStatus.Approved => "bg-green-100 text-green-700",
        TransactionStatus.Cancelled => "bg-red-100 text-red-700",
        _ => "bg-slate-100 text-slate-600"
    };
}